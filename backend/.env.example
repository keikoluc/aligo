PORT=4000

# Leave unset for local development: the backend uses a local SQLite
# file (backend/aligo.sqlite) automatically. When deploying, set this
# to a Postgres connection string and the backend switches over to
# Postgres automatically — no code changes needed.
# DATABASE_URL=postgres://user:password@host:5432/aligo

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d

OTP_TTL_MINUTES=5

# Mapbox access token used server-side to fetch driving-route distance
# for cargo price estimates (the same public token the Flutter app uses).
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-access-token

# Path to the Firebase service account JSON key (Project settings >
# Service accounts > Generate new private key), used to send push
# notifications. Leave unset to disable pushes without breaking the app.
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Password for the /admin dashboard. Leave unset to disable admin login.
ADMIN_PASSWORD=replace-with-a-strong-password

# Telegram bot token from @BotFather (send /newbot, follow the prompts).
# Leave unset to disable the bot without breaking the app — same
# graceful-skip pattern as FIREBASE_SERVICE_ACCOUNT_PATH above.
# TELEGRAM_BOT_TOKEN=123456789:AAour-bot-token-from-botfather

# Public HTTPS URL where the Mini App (backend/miniapp/) is reachable —
# Telegram refuses http:// and local IPs, so this only works once the
# backend is deployed behind a real domain (or tunneled with ngrok for
# testing). Leave unset to skip wiring the bot's menu button/app links;
# the bot's chat commands still work fine without it.
# TELEGRAM_MINIAPP_URL=https://your-domain.com/miniapp
