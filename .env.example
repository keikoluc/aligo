# Used by `docker compose up` (see docker-compose.yml) to configure the
# production-style stack (backend + Postgres). Copy to .env and fill in.
# For plain local dev (`node src/server.js`, no Docker), use
# backend/.env.example instead — SQLite needs none of this.

POSTGRES_PASSWORD=replace-with-a-strong-password
BACKEND_PORT=4000

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d
OTP_TTL_MINUTES=5

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

MAPBOX_ACCESS_TOKEN=pk.your-mapbox-access-token

ADMIN_PASSWORD=replace-with-a-strong-password

# Telegram bot token from @BotFather. Leave unset to disable the bot.
# TELEGRAM_BOT_TOKEN=123456789:AAour-bot-token-from-botfather

# Public HTTPS URL for the Mini App (see docker-compose.yml — Telegram
# requires a real domain, not http:// or a bare IP). Leave unset to skip.
# TELEGRAM_MINIAPP_URL=https://your-domain.com/miniapp
